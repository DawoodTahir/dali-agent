# ---- Core ----
PORT=8080
# Comma-separated allowed origins for the frontend (dev default below).
CORS_ORIGIN=http://localhost:5173

# Agency identity — shapes the agent's scope and phrasing.
AGENCY_NAME=DALI Agency
AGENCY_DESCRIPTION=a creative and brand agency that does brand identity, campaigns and design for D2C and growth-stage companies

# ---- Qualification bar ----
# Score >= QUALIFY_THRESHOLD  -> hand off to a human.
# Score <  DISQUALIFY_THRESHOLD once slots are exhausted -> close politely.
QUALIFY_THRESHOLD=75
DISQUALIFY_THRESHOLD=40

# ---- LLM (optional) ----
# With no key, the engine uses a deterministic mock so the POC still runs.
ANTHROPIC_API_KEY=
LLM_MODEL=claude-haiku-4-5-20251001

# ---- WhatsApp Cloud API (optional — Simulator needs none of this) ----
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_APP_SECRET=
GRAPH_API_VERSION=v21.0

# ---- Hosting ----
# Set to 1 to serve the built web/dist from Express (single deploy).
SERVE_WEB=
